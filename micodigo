    fun checkForUpdates() {
        val remoteConfig = Firebase.remoteConfig

        // Configuración de intervalo de escaneo
        val configSettings = remoteConfigSettings {
            minimumFetchIntervalInSeconds = 3600
        }
        remoteConfig.setConfigSettingsAsync(configSettings)

        // Traer los datos del servidor
        remoteConfig.fetchAndActivate().addOnCompleteListener { task ->
            if (task.isSuccessful) {
                val lastVersionCode = remoteConfig.getLong("last_version_code")
                val updateUrl = remoteConfig.getString("update_url")

                // --- OBTENER VERSIÓN ACTUAL SIN USAR BUILDCONFIG ---
                val currentVersionCode = if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.P) {
                    packageManager.getPackageInfo(packageName, 0).longVersionCode
                } else {
                    @Suppress("DEPRECATION")
                    packageManager.getPackageInfo(packageName, 0).versionCode.toLong()
                }

                // Comparar con la versión instalada
                if (lastVersionCode > currentVersionCode) {
                    showUpdateDialog(updateUrl)
                }
            }
        }
    }


    private fun showUpdateDialog(url: String) {
        val builder = AlertDialog.Builder(this)
            .setTitle("Actualización Disponible")
            .setMessage("Para seguir usando la app, debes instalar la última versión.")
            .setCancelable(false) // Bloquea clics fuera y botón atrás
            .setPositiveButton("Actualizar ahora", null) // Ponemos null para controlar el clic manualmente

        val dialog = builder.create()
        dialog.show()

        // Configuramos el clic así para que el diálogo no se cierre al presionar
        dialog.getButton(AlertDialog.BUTTON_POSITIVE).setOnClickListener {
            dialog.getButton(AlertDialog.BUTTON_POSITIVE).isEnabled = false // Deshabilitar para evitar múltiples clics
            downloadAndInstall(url, dialog)
        }
    }

    @SuppressLint("Range")
    private fun downloadAndInstall(url: String, dialog: AlertDialog) {
        // 1. LIMPIEZA: Borrar APKs viejos para no llenar la TV Box
        externalCacheDir?.listFiles()?.forEach { file ->
            if (file.name.startsWith("update") && file.name.endsWith(".apk")) {
                file.delete()
            }
        }

        // 2. NUEVO NOMBRE: Usamos timestamp para que el DownloadManager no se bloquee
        val destination = File(externalCacheDir, "update_${System.currentTimeMillis()}.apk")

        val manager = getSystemService(DOWNLOAD_SERVICE) as DownloadManager
        val request = DownloadManager.Request(Uri.parse(url))
            .setTitle("Descargando actualización...")
            .setNotificationVisibility(DownloadManager.Request.VISIBILITY_VISIBLE_NOTIFY_COMPLETED)
            .setDestinationUri(Uri.fromFile(destination))

        val downloadId = manager.enqueue(request)

        // 3. PROGRESO: Corrutina para actualizar el diálogo en tiempo real
        lifecycleScope.launch {
            var downloading = true
            while (downloading) {
                val query = DownloadManager.Query().setFilterById(downloadId)
                val cursor = manager.query(query)
                if (cursor != null && cursor.moveToFirst()) {
                    @SuppressLint("Range")
                    val bytesDownloaded = cursor.getInt(cursor.getColumnIndex(DownloadManager.COLUMN_BYTES_DOWNLOADED_SO_FAR))
                    @SuppressLint("Range")
                    val bytesTotal = cursor.getInt(cursor.getColumnIndex(DownloadManager.COLUMN_TOTAL_SIZE_BYTES))

                    if (bytesTotal > 0) {
                        val progress = (bytesDownloaded * 100L / bytesTotal)
                        // Actualizamos el mensaje del diálogo que ya está visible
                        dialog.setMessage("Descargando: $progress% (${bytesDownloaded / 1024} KB / ${bytesTotal / 1024} KB)")
                    }

                    @SuppressLint("Range")
                    val status = cursor.getInt(cursor.getColumnIndex(DownloadManager.COLUMN_STATUS))
                    when (status) {
                        DownloadManager.STATUS_SUCCESSFUL -> {
                            downloading = false
                            installApk(destination)
                            dialog.dismiss() // Cerramos el diálogo al terminar
                        }
                        DownloadManager.STATUS_FAILED -> {
                            downloading = false
                            dialog.setMessage("Error en la descarga. Intenta de nuevo.")
                            dialog.getButton(AlertDialog.BUTTON_POSITIVE).isEnabled = true
                        }
                    }
                    cursor.close()
                }
                delay(500) // Revisa el estado cada medio segundo
            }
        }
    }

    private fun installApk(file: java.io.File) {
        val uri = androidx.core.content.FileProvider.getUriForFile(
            this, "$packageName.fileprovider", file
        )
        val intent = Intent(Intent.ACTION_VIEW)
        intent.setDataAndType(uri, "application/vnd.android.package-archive")
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        startActivity(intent)
    }

    private fun escucharServidoresFirebase() {
        val database = com.google.firebase.ktx.Firebase.database.reference.child("servidores")

        database.addValueEventListener(object : com.google.firebase.database.ValueEventListener {
            override fun onDataChange(snapshot: com.google.firebase.database.DataSnapshot) {
                val eraListaVacia = listaServidores.isEmpty()
                listaServidores.clear()

                for (data in snapshot.children) {
                    val srv = data.getValue(ServidorIPTV::class.java)
                    srv?.let { listaServidores.add(it) }
                }

                if (eraListaVacia && listaServidores.isNotEmpty()) {
                    mostrarSelectorDeServidor()
                }
            }

            override fun onCancelled(error: com.google.firebase.database.DatabaseError) {
                Toast.makeText(this@MainActivity, "Error Firebase: ${error.message}", Toast.LENGTH_SHORT).show()
            }
        })
    }
