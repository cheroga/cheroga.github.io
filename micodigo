    // Dentro de tu lógica de carga de Firebase/Servidor
    private fun cargarLista(url: String) {
        lifecycleScope.launch(Dispatchers.IO) {
            try {
                val request = Request.Builder().url(url).build()

                // Usamos .execute() dentro de un bloque 'use' para que la respuesta se cierre sola
                client.newCall(request).execute().use { response ->
                    if (!response.isSuccessful) throw java.io.IOException("Error: $response")

                    // IMPORTANTE: body no lleva paréntesis, string() sí.
                    val content = response.body()?.string() ?: ""

                    withContext(Dispatchers.Main) {
                        val canalesExtraidos = if (url.contains(".m3u") || content.contains("#EXTM3U")) {
                            procesarM3U(content)
                        } else {
                            parseJson(content)
                        }

                        val titulo = if (url.contains("py.m3u")) "Canales de Paraguay" else "Lista de Canales"
                        val nuevaCategoria = CategoriaConCanales(titulo, canalesExtraidos)
                        actualizarInterfaz(listOf(nuevaCategoria))
                    }
                }
            } catch (e: Exception) {
                Log.e("ERROR_CARGA", "Error en body: ${e.message}")
            }
        }
    }
