private fun procesarM3U(contenido: String): List<Sample> {
    val lista = mutableListOf<Sample>()
    val lineas = contenido.lines()
    var nombreActual = ""
    var tvgIdActual = ""
    var refererActual: String? = null

    for (linea in lineas) {
        val l = linea.trim()
        when {
            l.startsWith("#EXTINF") -> {
                nombreActual = l.substringAfterLast(",").trim()
                tvgIdActual = l.substringAfter("tvg-id=\"", "").substringBefore("\"", "")
            }
            l.startsWith("#EXTVLCOPT:http-referrer=") -> {
                refererActual = l.substringAfter("=").trim()
            }
            l.startsWith("http") -> {
                // Mapeamos el Referer a headersUrl para que el motor lo use
                val headers = if (refererActual != null) mapOf("Referer" to refererActual) else null

                lista.add(Sample(
                    name = nombreActual,
                    url = l,
                    headersUrl = headers,
                    icono = "https://cheroga.github.io/jejru2.png" // Puedes poner un logo por defecto
                ))
                refererActual = null
            }
        }
    }
    return lista
}
    // Asegúrate de que devuelva List<Sample>
    private fun parseJson(jsonString: String): List<Sample> {
        val lista = mutableListOf<Sample>()
        try {
            // 1. Intentamos leerlo como un Array directo [{}, {}]
            val array = if (jsonString.trim().startsWith("[")) {
                JSONArray(jsonString)
            } else {
                // 2. Si viene envuelto en un objeto {"samples": []} o {"canales": []}
                val root = JSONObject(jsonString)
                root.optJSONArray("samples") ?: root.optJSONArray("canales") ?: JSONArray()
            }

            for (i in 0 until array.length()) {
                val obj = array.getJSONObject(i)
                lista.add(Sample(
                    name = obj.optString("name"),
                    url = obj.optString("url"),
                    icono = obj.optString("icono"),
                    type = obj.optString("type", "PELICULA"),

                    // --- CAMPOS PARA EXPERIENCIA NETFLIX ---
                    descripcion = obj.optString("descripcion"),
                    anio = obj.optString("anio"),
                    duracion = obj.optString("duracion"),
                    genero = obj.optString("genero"),
                ))
            }
        } catch (e: Exception) {
            Log.e("JSON_ERROR", "Error crítico: ${e.message}")
        }
        return lista
    }


    private fun actualizarInterfaz(listaCategorias: List<CategoriaConCanales>) {
        val mainAdapter = MainVerticalAdapter(listaCategorias) { canal ->

            // 1. Detectamos si es una Película primero
            if (canal.type?.uppercase() == "PELICULA") {
                Log.d("RASTREO", "Abriendo Detalles de Película: ${canal.name}")
                abrirDetallesPelicula(canal) // Función que crearemos abajo
                return@MainVerticalAdapter // Salimos para no ejecutar lo de los canales
            }

            // 2. Si no es película, seguimos con tu lógica original para canales
            val url = canal.url?.lowercase() ?: ""

            when {
                // Caso A: Canales con extensiones directas
                url.contains(".m3u8") || url.contains(".ts") || url.contains(".mpd") -> {
                    Log.d("RASTREO", "Reproducción directa/DRM: ${canal.name}")
                    // Pasamos todos los parámetros para que CLEARKEY siga funcionando
                    prepararMotorYReproducir(
                        canal.url!!,
                        canal.drm_license_uri,
                        canal.type,
                        canal.headersUrl
                    )
                }
                // Caso B: Todo lo demás (Webview / Páginas de deportes)
                else -> {
                    Log.d("RASTREO", "Iniciando WebView: ${canal.name}")
                    extraerUrlDeWebView(canal)
                }
            }
        }

        rvCanales.adapter = mainAdapter
    }
