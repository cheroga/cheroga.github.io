package com.moisnostudio.jerutiapp.ui

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.moisnostudio.jerutiapp.R
import com.moisnostudio.jerutiapp.model.Sample

class MainVerticalAdapter(
    private val categorias: List<com.moisnostudio.jerutiapp.model.CategoriaConCanales>,
    private val onCanalClick: (Sample) -> Unit
) : RecyclerView.Adapter<MainVerticalAdapter.ViewHolder>() {

    // 1. Definimos los tipos de vista
    companion object {
        const val TYPE_HORIZONTAL = 0
        const val TYPE_POSTER = 1
    }

    init {
        setHasStableIds(true)
    }

    // 2. Determinamos qué tipo de vista usar según el modelo
    override fun getItemViewType(position: Int): Int {
        // Si es POSTER_VERTICAL devolvemos 1, si no 0
        return if (categorias[position].viewType == "POSTER_VERTICAL") 1 else 0
    }

    override fun getItemId(position: Int): Long {
        return categorias[position].titulo.hashCode().toLong()
    }

    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val txtTitulo: TextView = view.findViewById(R.id.txtTituloCategoria)
        val rvHorizontal: RecyclerView = view.findViewById(R.id.rvHorizontal)
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        // 3. Aquí podrías inflar layouts diferentes si el diseño de la fila cambia mucho
        // Por ahora usamos el mismo contenedor de RecyclerView
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_fila_categoria, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val item = categorias[position]
        holder.txtTitulo.text = item.titulo

        // 1. Configuramos el LayoutManager ANTES del adapter
        holder.rvHorizontal.apply {
            // Si ya tiene uno, no lo volvemos a crear (optimización)
            if (layoutManager == null) {
                layoutManager = LinearLayoutManager(context, LinearLayoutManager.HORIZONTAL, false)
            }

            // 2. Asignamos el adaptador con el viewType (Netflix o Normal)
            adapter = CanalHorizontalAdapter(
                item.canales,
                item.viewType,
                onCanalClick
            )

            // 3. Configuraciones de foco para Android TV
            isFocusable = false
            descendantFocusability = ViewGroup.FOCUS_AFTER_DESCENDANTS

            // Limpiamos caché para evitar que se mezclen posters con cuadrados
            recycledViewPool.clear()
        }
    }


    override fun getItemCount() = categorias.size
}
