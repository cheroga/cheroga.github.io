    private fun cargarCanales(urlFinal: String) {
        // 1. Estado inicial (Tu lógica original pág. 6)
        rvCanales.alpha = 0f
        rvCanales.visibility = View.VISIBLE
        progressBar.visibility = View.VISIBLE
        imgFondoInicio.visibility = View.VISIBLE
        layoutError.visibility = View.GONE

        lifecycleScope.launch {
            try {
                val content = withContext(Dispatchers.IO) {
                    // Usamos OkHttp para obtener el texto plano primero y decidir qué es
                    val request = Request.Builder().url(urlFinal).build()
                    client.newCall(request).execute().body()?.string() ?: ""
                }

                var listaFinal = listOf<CategoriaConCanales>()
                val servidorActual = listaServidores.find { it.url == urlFinal }
                val viewType = servidorActual?.viewType ?: "DEFAULT"

                // 2. DETECCIÓN DE FORMATO
                when {
                    content.contains("#EXTM3U") -> {
                        val listaM3U = procesarM3U(content)
                        listaFinal = listOf(CategoriaConCanales("Lista M3U", listaM3U))
                    }
                    content.trim().startsWith("{") && !content.contains("\"samples\"") -> {
                        // Es el formato de streametx (JSONObject con categorías como llaves)
                        listaFinal = parsearCategoriasDesdeJson(content)
                    }
                    else -> {
                        val parsedList = withContext(Dispatchers.IO) {
                            try {
                                // Como ApiService ahora devuelve List<IptvData>,
                                // 'parsedList' ya recibe la lista directamente.
                                RetrofitClient.instance.getIptvData(urlFinal)
                            } catch (e: Exception) {
                                android.util.Log.e("IPTV_ERROR", "Error en Retrofit: ${e.message}")
                                emptyList<IptvData>()
                            }
                        }

                        // El .map ahora funcionará perfectamente porque 'parsedList' es una List
                        listaFinal = parsedList.map { data ->
                            CategoriaConCanales(
                                titulo = data.name ?: "General",
                                canales = data.samples ?: emptyList(),
                                viewType = viewType
                            )
                        }
                    }
                }

                // 3. ACTUALIZAR UI (Tu lógica original pág. 7)
                withContext(Dispatchers.Main) {
                    if (listaFinal.isNotEmpty()) {
                        // Si es Películas, forzamos el LayoutManager vertical para las filas
                        rvCanales.layoutManager = LinearLayoutManager(this@MainActivity)
                        rvCanales.adapter = MainVerticalAdapter(listaFinal) { canal ->
                            reproducirCanal(canal)
                        }
                        finalizarCargaExitosa()
                    } else {
                        manejarErrorCarga("No hay contenidos disponibles")
                    }
                }

            } catch (e: Exception) {
                withContext(Dispatchers.Main) {
                    android.util.Log.e("IPTV_ERROR", "Error: ${e.message}")
                    manejarErrorCarga("Error de conexión")
                }
            }
        }
    }

    private fun parsearCategoriasDesdeJson(jsonString: String): List<CategoriaConCanales> {
        val listaCategorias = mutableListOf<CategoriaConCanales>()
        try {
            val root = JSONObject(jsonString)
            val keys = root.keys() // Aquí saca "LANCTV", "PARAGUAY", etc.

            while (keys.hasNext()) {
                val nombreCat = keys.next()
                val arrayCanales = root.getJSONArray(nombreCat)
                val listaCanales = mutableListOf<Sample>()

                // --- AQUÍ ES DONDE ENTRAS A PROCESAR CADA CANAL ---
                for (i in 0 until arrayCanales.length()) {
                    val obj = arrayCanales.getJSONObject(i)

// Dentro de tu parser manual, cuando creas el Sample:
                    // Lógica "Inteligente": Si tiene logo úsalo, si no, busca icono
                    val imagenFinal = when {
                        obj.has("logo") -> obj.optString("logo")
                        obj.has("icono") -> obj.optString("icono")
                        else -> "" // O una URL de imagen por defecto
                    }

                    listaCanales.add(Sample(
                        name = obj.optString("nombre").ifEmpty { obj.optString("name") },
                        url = obj.optString("url"),
                        icono = imagenFinal, // Aquí guardamos cualquiera de los dos en tu variable 'icono'
                        type = obj.optString("type")
                    ))
                }
                // -------------------------------------------------

                if (listaCanales.isNotEmpty()) {
                    listaCategorias.add(CategoriaConCanales(nombreCat, listaCanales))
                }
            }
        } catch (e: Exception) {
            Log.e("JSON_ERROR", "Error parseando: ${e.message}")
        }
        return listaCategorias
    }

