    @OptIn(UnstableApi::class)
    private fun setupPlayer() {
        val loadControl = DefaultLoadControl.Builder()
            .setBufferDurationsMs(
                50_000, // Min buffer: 25 seg antes de dar error
                60_000, // Max buffer: 60 seg de precarga
                5_000,  // Buffer para iniciar: 3 seg
                5_000   // Buffer para reanudar
            )
            .setPrioritizeTimeOverSizeThresholds(true)
            //.setBackBuffer(10_000, true)
            .build()

        player = ExoPlayer.Builder(this)
            .setLoadControl(loadControl)
            .setSeekBackIncrementMs(15000)    // <--- Configura 15 segundos atrás
            .setSeekForwardIncrementMs(15000) // <--- Configura 15 segundos adelante
            .build()

        playerView.player = player
        playerView.useController = true
        playerView.resizeMode = AspectRatioFrameLayout.RESIZE_MODE_ZOOM

// O RESIZE_MODE_FILL si no te importa que se estire un poco
        player.addListener(object : Player.Listener {
            override fun onPlayerError(error: PlaybackException) {
                progressBar.visibility = View.GONE
                layoutError.visibility = View.VISIBLE

                txtMensajeError.text = when (error.errorCode) {
                    PlaybackException.ERROR_CODE_IO_NETWORK_CONNECTION_FAILED -> "Conexión inestable, reintentando..."
                    PlaybackException.ERROR_CODE_DRM_LICENSE_ACQUISITION_FAILED -> "Error de Licencia DRM"
                    else -> "Buscando señal..."
                }

                playerView.postDelayed({
                    if (layoutError.visibility == View.VISIBLE) {
                        player.prepare()
                        player.play()
                        // No llamamos a onBackPressed() para no salir del canal
                    }
                }, 4000) // Esperamos 4 segundos para que el internet respire
            }
            override fun onPlaybackStateChanged(state: Int) {
                // 1. Manejo del ProgressBar (Tu lógica original)
                progressBar.visibility = if (state == Player.STATE_BUFFERING) View.VISIBLE else View.GONE

                when (state) {
                    Player.STATE_BUFFERING -> {
                        // OPTIMIZACIÓN: Si el buffer se queda corto, ocultamos la superficie
                        // para que se vea negro en lugar de una imagen congelada.
                        playerView.videoSurfaceView?.visibility = View.INVISIBLE
                    }

                    Player.STATE_READY -> {
                        // 2. Quitamos el error (Tu lógica original)
                        layoutError.visibility = View.GONE

                        // OPTIMIZACIÓN: Solo mostramos la superficie cuando el video está listo
                        playerView.videoSurfaceView?.visibility = View.VISIBLE
                    }

                    Player.STATE_IDLE -> {
                        // Si el player se detiene por error o cambio de canal, volvemos a negro
                        playerView.videoSurfaceView?.visibility = View.INVISIBLE
                    }
                }
            }
           /*override fun onPlaybackStateChanged(state: Int) {
                progressBar.visibility = if (state == Player.STATE_BUFFERING) View.VISIBLE else View.GONE
                if (state == Player.STATE_READY) {
                    layoutError.visibility = View.GONE
                }
            }*/
        })
    }
    private fun aplicarEfectoFocus(view: View) {
        view.setOnFocusChangeListener { v, hasFocus ->
            if (hasFocus) {
                // Se agranda un 15% y se trae al frente
                v.animate().scaleX(1.15f).scaleY(1.15f).translationZ(10f).setDuration(200).start()
            } else {
                // Vuelve a su tamaño original
                v.animate().scaleX(1f).scaleY(1f).translationZ(0f).setDuration(200).start()
            }
        }
    }

