    @OptIn(UnstableApi::class)
    override fun dispatchKeyEvent(event: KeyEvent): Boolean {
        if (playerView.visibility == View.VISIBLE) {
            if (playerView.dispatchKeyEvent(event)) {
                return true
            }
            val teclasCriticas = event.keyCode == KeyEvent.KEYCODE_DPAD_CENTER ||
                    event.keyCode == KeyEvent.KEYCODE_ENTER ||
                    event.keyCode == KeyEvent.KEYCODE_DPAD_UP ||
                    event.keyCode == KeyEvent.KEYCODE_DPAD_DOWN ||
                    event.keyCode == KeyEvent.KEYCODE_DPAD_LEFT ||
                    event.keyCode == KeyEvent.KEYCODE_DPAD_RIGHT

            if (teclasCriticas) {
                if (event.action == KeyEvent.ACTION_DOWN) {
                    playerView.showController()
                    playerView.requestFocus() // Aseguramos que el foco vuelva al player
                }
                return true // RETORNAMOS TRUE SIEMPRE: Esto mata el evento para la lista de atrás
            }
        }
        return super.dispatchKeyEvent(event)
    }

