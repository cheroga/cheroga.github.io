            R.layout.item_canal_horizontal // El tuyo actual: Diseño horizontal
        }

        val view = LayoutInflater.from(parent.context).inflate(layout, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val canal = canales[position]

        holder.nombre.text = canal.name

        // Glide se adapta automáticamente al tamaño del ImageView
        Glide.with(holder.itemView.context)
            .load(canal.icono)
            .transform(CenterCrop(), RoundedCorners(12))
            .into(holder.icono)

        holder.itemView.setOnClickListener { onCanalClick(canal) }

        // Mantenemos intacto tu efecto de foco (Android TV)
        holder.itemView.setOnFocusChangeListener { view, hasFocus ->
            if (hasFocus) {
                view.animate().scaleX(1.12f).scaleY(1.12f).setDuration(200).start()
                view.setBackgroundResource(R.drawable.bg_focus_canal)
                view.z = 10f
            } else {
                view.animate().scaleX(1.0f).scaleY(1.0f).setDuration(200).start()
                view.setBackgroundResource(android.R.color.transparent)
                view.z = 0f
            }
        }
    }

    override fun getItemCount() = canales.size
}
