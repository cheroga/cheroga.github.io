    @androidx.annotation.OptIn(androidx.media3.common.util.UnstableApi::class)
    private fun extraerUrlDeWebView(canal: Sample) {
        // IMPORTANTE: El WebView necesita el contexto de la Activity, no solo 'this' si es un Fragment
        val webView = android.webkit.WebView(this)

        // CONFIGURACIÓN DE TAMAÑO (Crucial para que carguen los scripts de video)
        webView.layoutParams = android.view.ViewGroup.LayoutParams(1, 1) // 1x1 pixel
        webView.visibility = android.view.View.VISIBLE // Debe estar visible para el sistema
        webView.alpha = 0.1f // Casi transparente para que el usuario no lo note

        // Añadirlo al layout principal de tu activity temporalmente
        val rootLayout = findViewById<android.view.ViewGroup>(android.R.id.content)
        rootLayout.addView(webView)

        webView.settings.javaScriptEnabled = true
        webView.settings.domStorageEnabled = true // Muchos sitios lo necesitan para el token
        webView.settings.mediaPlaybackRequiresUserGesture = false // Para que el video intente iniciar solo

        val ua = canal.headersUrl?.get("User-Agent") ?: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        webView.settings.userAgentString = ua

        webView.webViewClient = object : android.webkit.WebViewClient() {
            override fun shouldInterceptRequest(view: android.webkit.WebView?, request: android.webkit.WebResourceRequest?): android.webkit.WebResourceResponse? {
                val urlDetectada = request?.url.toString()

                // Log en Error para que resalte en ROJO
                android.util.Log.e("RASTREO_TOTAL", "PETICIÓN: $urlDetectada")

                if (urlDetectada.contains(".m3u8", ignoreCase = true) ||
                    urlDetectada.contains(".mpd", ignoreCase = true) ||
                    urlDetectada.contains(".mp4", ignoreCase = true)) {

                    android.util.Log.e("CAPTURADOR_EXITO", "¡VÍDEO ENCONTRADO!: $urlDetectada")

                    runOnUiThread {
                        // Limpieza: Lo sacamos del layout antes de destruir
                        rootLayout.removeView(webView)
                        webView.stopLoading()
                        webView.destroy()
                        prepararMotorYReproducir(urlDetectada, null, "DIRECT", canal.headersUrl)
                    }
                }
                return super.shouldInterceptRequest(view, request)
            }
        }

        val extraHeaders = mutableMapOf<String, String>()
        // Si el sitio pide Referer para cargar la web principal, añádelo aquí
        canal.headersUrl?.get("Referer")?.let { extraHeaders["Referer"] = it }

        canal.url?.let { urlSegura ->
            webView.loadUrl(urlSegura, extraHeaders)
        }
    }
    @androidx.annotation.OptIn(androidx.media3.common.util.UnstableApi::class)
    private fun prepararMotorYReproducir(url: String, drmUri: String?, type: String?, headers: Map<String, String>?) {
        // 1. Configuración del MediaItem (Una sola vez, bien estructurada)
        // --- NUEVA LÓGICA DE LIMPIEZA ---
        // Si la url contiene "?hls", lo eliminamos para estabilizar la señal
        val urlLimpia = if (url.contains("?hls")) {
            url.split("?hls")[0]
        } else {
            url
        }
        android.util.Log.e("ESTABILIZADOR", "URL Original: $url")
        android.util.Log.e("ESTABILIZADOR", "URL Limpia: $urlLimpia")
        // --------------------------------

        // Ahora usamos 'urlLimpia' en lugar de 'url'
        val mediaItemBuilder = MediaItem.Builder()
            .setUri(urlLimpia)
            .setLiveConfiguration(
                MediaItem.LiveConfiguration.Builder()
                    .setTargetOffsetMs(15_000)
                    .build()
            )
        // Si es ClearKey, lo añadimos al builder ANTES del build()
        if (type?.uppercase() == "CLEARKEY") {
            mediaItemBuilder.setDrmConfiguration(
                MediaItem.DrmConfiguration.Builder(C.CLEARKEY_UUID)
                    .setLicenseUri(drmUri)
                    .build()
            )
        }

        val mediaItem = mediaItemBuilder.build()

        // 2. Configuración del DataSource con Headers y Timeouts largos
        val dataSourceFactory = androidx.media3.datasource.DefaultHttpDataSource.Factory()
            .setDefaultRequestProperties(headers ?: emptyMap())
            .setConnectTimeoutMs(20_000) // 20 segundos para servidores lentos
            .setReadTimeoutMs(20_000)
            .setAllowCrossProtocolRedirects(true)

        // 3. Factory de reintentos automáticos (El "tanque" contra errores de red)
        val retryingDataSourceFactory = androidx.media3.datasource.DefaultDataSource.Factory(
            this,
            dataSourceFactory
        )

        // 4. Creación del MediaSource Inteligente (Adaptable)
        val mediaSource = when {
            // Caso 1: DRM o DASH
            urlLimpia.contains(".mpd") || type?.uppercase() == "CLEARKEY" -> {
                androidx.media3.exoplayer.dash.DashMediaSource.Factory(retryingDataSourceFactory)
                    .createMediaSource(mediaItem)
            }
            // Caso 2: Películas MP4
            urlLimpia.lowercase().endsWith(".mp4") || type?.uppercase() == "PELICULA" -> {
                androidx.media3.exoplayer.source.ProgressiveMediaSource.Factory(retryingDataSourceFactory)
                    .createMediaSource(mediaItem)
            }
            // Caso 3: TU LÓGICA ORIGINAL PARA HLS (Canales m3u8)
            else -> {
                androidx.media3.exoplayer.hls.HlsMediaSource.Factory(retryingDataSourceFactory)
                    .setAllowChunklessPreparation(false)
                    .createMediaSource(mediaItem)
            }
        }

        // 5. Carga y Reproducción
        player.setMediaSource(mediaSource)
        player.prepare()
        player.play()
    }

    @OptIn(UnstableApi::class)
    @SuppressLint("MissingSuperCall")
    override fun onBackPressed() {
        // CASO A: Salir del Reproductor al listado de canales
        if (playerView.visibility == View.VISIBLE) {
            // 1. Detener reproducción y limpiar pantalla
            player.stop()
            player.clearMediaItems()
            playerView.visibility = View.GONE
            window.clearFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
            layoutInfoCanal.visibility = View.GONE

            // 2. Asegurar que el RecyclerView sea visible y focuseable
            rvCanales.visibility = View.VISIBLE
            rvCanales.alpha = 1f
            rvCanales.descendantFocusability = ViewGroup.FOCUS_AFTER_DESCENDANTS

            // 3. Recuperar el foco donde el usuario estaba
            rvCanales.post {
                val view = rvCanales.layoutManager?.findViewByPosition(ultimaPosicionCanal)
                if (view != null && view.isAttachedToWindow) {
                    view.requestFocus()
                } else {
                    rvCanales.scrollToPosition(ultimaPosicionCanal)
                    rvCanales.requestFocus()
                }
            }
            return // Bloqueamos la salida de la app
        }

        // CASO B: Salir del listado de canales al Selector de Servidores
        if (rvCanales.visibility == View.VISIBLE) {
            // 1. Ocultar canales y mostrar fondo de inicio
            rvCanales.visibility = View.GONE
            imgFondoInicio.visibility = View.VISIBLE
            imgFondoInicio.alpha = 1f // Lo mostramos sólido de nuevo

            // 2. Volver al menú de selección (la función que creamos ayer)
            mostrarSelectorDeServidor()
            return
        }
        mostrarDialogoSalir()

    }
