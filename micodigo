package com.moisnostudio.jerutiapp.ui

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import com.bumptech.glide.Glide
import com.moisnostudio.jerutiapp.R
import com.moisnostudio.jerutiapp.model.ServidorIPTV

class ServidoresAdapter(
    private val servidores: List<ServidorIPTV>,
    private val onServerSelected: (ServidorIPTV) -> Unit
) : RecyclerView.Adapter<ServidoresAdapter.ViewHolder>() {

    // 1. EL VIEWHOLDER: Aquí vinculamos los elementos del XML (item_servidor.xml)
    class ViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val nombre: TextView = view.findViewById(R.id.txtNombreServidor)
        val imgLogo: ImageView = view.findViewById(R.id.imgLogoServidor)
    }

    // 2. CREAR LA VISTA: Infla el diseño de la tarjeta
    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_servidor, parent, false)
        return ViewHolder(view)
    }

    // 3. CARGAR DATOS: Aquí ocurre la magia de Netflix y el foco de la TV
    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        val servidor = servidores[position]

        holder.nombre.text = servidor.nombre

        // Carga la imagen de Firebase usando Glide
        Glide.with(holder.itemView.context)
            .load(servidor.logo)
            .placeholder(android.R.drawable.ic_menu_gallery)
            .error(android.R.drawable.ic_menu_report_image)
            .into(holder.imgLogo)

        holder.itemView.isFocusable = true
        holder.itemView.isFocusableInTouchMode = true

        holder.itemView.setOnFocusChangeListener { v, hasFocus ->
            if (hasFocus) {
                // Efecto de agrandar cuando el usuario se posiciona encima
                v.animate().scaleX(1.1f).scaleY(1.1f).setDuration(200).start()
                v.elevation = 10f
            } else {
                // Volver al tamaño normal al quitar el foco
                v.animate().scaleX(1.0f).scaleY(1.0f).setDuration(200).start()
                v.elevation = 0f
            }
        }
        holder.itemView.setOnClickListener {
            onServerSelected(servidor)
        }
    }

    override fun getItemCount() = servidores.size
}
